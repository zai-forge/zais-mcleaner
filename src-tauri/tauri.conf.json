{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zais MCleaner",
  "version": "0.1.0",
  "identifier": "me.proton.zaipublic.mcleaner",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Zai's MCleaner",
        "width": 440,
        "height": 820,
        "minWidth": 360,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
